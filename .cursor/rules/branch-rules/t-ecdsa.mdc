# t-ecdsa
このファイルは作業ブランチがt-ecdsaの時だけ読み込まれる。


## 実現したいこと
ICPのキャニスターをNim言語で開発したい。
Management Canitserのecdsa_public_key関数を呼び出す処理をRustを参考に、どうすればできるか考える。

以下はRustでManagement Canisterを呼び出すコードの例です。
https://github.com/dfinity/cdk-rs/blob/main/ic-cdk/src/management_canister.rs
https://github.com/dfinity/cdk-rs/blob/main/ic-cdk/src/call.rs

以下はMotokoでのサンプルです。ICPのECDSA関数は引数の型が決まっています
canister_idは?Principal型で、nullを指定するとManagement Canisterを呼び出します。
derivation_pathは[Blob]型で、ここには呼び出し元のPrincipalのバイナリデータを指定します。
key_idは{ curve : { #secp256k1 }; name : Text }型で、curveはEnumであり、secp256k1を指定します。
nameはText型で、ここにはキーの名前を指定します。ローカル環境では定数の dfx_test_key を指定します。

```motoko
import Cycles "mo:base/ExperimentalCycles";
import Error "mo:base/Error";
import Principal "mo:base/Principal";
import Text "mo:base/Text";
import Blob "mo:base/Blob";
import Nat8 "mo:base/Nat8";
import Hex "./Hex";
import SHA256 "./SHA256";
import Debug "mo:base/Debug";
module {
  // Only the ecdsa methods in the IC management canister is required here.
  public type IC = actor {
    ecdsa_public_key : ({
      canister_id : ?Principal;
      derivation_path : [Blob];
      key_id : { curve : { #secp256k1 }; name : Text };
    }) -> async ({ public_key : Blob; chain_code : Blob });
    sign_with_ecdsa : ({
      message_hash : Blob;
      derivation_path : [Blob];
      key_id : { curve : { #secp256k1 }; name : Text };
    }) -> async ({ signature : Blob });
  };

  let ic : IC = actor("aaaaa-aa");

  public func public_key(_caller : Principal) : async [Nat8] {
    Debug.print("=== ecdsa public_key ===");
    let caller = Principal.toBlob(_caller);
    Debug.print("caller: " # debug_show (caller));
    try {
      let { public_key } = await ic.ecdsa_public_key({
        canister_id = null;
        derivation_path = [caller];
        key_id = { curve = #secp256k1; name = "dfx_test_key" };
      });
      return Blob.toArray(public_key);
    } catch (err) {
      let msg = Error.message(err);
      throw Error.reject(msg);
    };
  };

  public func sign(_caller : Principal, message : Blob) : async [Nat8] {
    let caller = Principal.toBlob(_caller);
    try {
      // Cycles.add(25_000_000_000);
      let { signature } = await ic.sign_with_ecdsa({
        message_hash = message;
        derivation_path = [caller];
        key_id = { curve = #secp256k1; name = "dfx_test_key" };
      });
      return Blob.toArray(signature);
    } catch (err) {
      let msg = Error.message(err);
      throw Error.reject(msg);
    };
  };
};
```

